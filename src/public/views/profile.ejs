<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Shopify - Premium Activewear & Fashion. Enjoy up to 50% off in our Winter Sale. Elevate your style with our curated collections.">
    <meta property="og:title" content="Shopify | Premium Activewear & Fashion">
    <meta property="og:description" content="Discover our winter collection with up to 50% off. Shop premium activewear and elevate your style.">
    <meta property="og:image" content="/assets/images/social-preview.jpg">

    <link rel="stylesheet" href="https://unicons.iconscout.com/release/v4.0.0/css/line.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="../css/global.css">
    <title>Profile</title>
    
    <link rel="preconnect" href="https://unicons.iconscout.com">
    <link rel="preconnect" href="https://cdnjs.cloudflare.com">
    <link rel="preconnect" href="https://fonts.googleapis.com">

    <style>
        .profile-container {
            max-width: 1100px;
            padding: 2rem 1.5rem;
            margin: 0 auto;
            min-height: 100vh;
        }

        .glass-card {
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.8), rgba(247, 231, 231, 0.6));
            border-radius: 0.5rem;
            box-shadow: rgba(60, 64, 67, 0.3) 0px 1px 2px 0px, rgba(60, 64, 67, 0.15) 0px 1px 3px 1px;
        }

        .profile-header {
            margin-bottom: 2rem;
        }

        .profile-header-content {
            padding: 1rem;
            
        }

        .profile-info {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .avatar-section {
            position: relative;
        }

        .avatar {
            width: 6rem;
            height: 6rem;
            border-radius: 50%;
            border: 2px solid #ebd1b6;
            background-color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            font-weight: 600;
            color: #8b6f47;
        }

        .user-details {
            flex: 1;
        }

        .user-header {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .user-name {
            font-size: 1.5rem;
            font-weight: bold;
            font-family: 'Cormorant Garamond', serif;
            color: #111827;
            margin-bottom: 0.5rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 100%;
        }

        .user-email {
            color: #6b7280;
            margin-bottom: 0.75rem;
        }

        .user-stats {
            display: flex;
            align-items: center;
            gap: 1rem;
            font-size: 0.875rem;
            color: #6b7280;
        }

        .stat-item {
            display: flex;
            align-items: center;
            gap: 0.25rem;
        }

        .badge {
            background-color: rgba(235, 209, 182, 0.2);
            color: #8b6f47;
            border: 1px solid #ebd1b6;
            padding: 0.25rem 0.5rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 500;
        }

        .profile-actions {
            display: flex;
            gap: 0.75rem;
        }

        .btn {
            padding: 0.5rem 1rem;
            border-radius: 0.375rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            border: none;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.875rem;
        }

        .btn-outline {
            border: 1px solid #ebd1b6;
            color: #8b6f47;
            background: transparent;
        }

        .btn-outline:hover {
            background-color: rgba(235, 209, 182, 0.1);
        }

        .btn-primary {
            background-color: #ebd1b6;
            color: #8b6f47;
        }

        .btn-primary:hover {
            background-color: #d4c0a1;
        }

        .tabs-container {
            margin-bottom: 1.5rem;
        }

        .tabs {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(4px);
            border: 1px solid rgba(235, 209, 182, 0.2);
            border-radius: 0.5rem;
            padding: 0.25rem;
        }

        .tab-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            border-radius: 0.375rem;
            background: none;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
            color: #374151;
        }

        .tab-btn:hover:not(.active) {
            background-color: #f3f4f6;
        }

        .tab-btn.active {
            background-color: #ebd1b6;
            color: #8b6f47;
        }

        .tab-content {
            display: block;
        }

        .tab-content.hidden {
            display: none;
        }

        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.5rem;
        }

        .section-title {
            font-size: 1.5rem;
            font-weight: bold;
            color: #111827;
            flex: 1;
        }

        .orders-list {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .order-card {
            padding: 1.5rem;
        }

        .order-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1rem;
        }

        .order-info {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .order-details h3 {
            font-weight: 600;
            color: #111827;
            margin-bottom: 0.25rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 100%;
        }

        .order-details p {
            font-size: 0.875rem;
            color: #6b7280;
        }

        .order-status {
            padding: 0.25rem 0.5rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 500;
        }

        .status-delivered {
            background-color: #d1fae5;
            color: #065f46;
        }

        .status-processing {
            background-color: rgba(235, 209, 182, 0.2);
            color: #8b6f47;
        }

        .order-total {
            text-align: right;
        }

        .order-total p {
            font-weight: 600;
            color: #111827;
            margin-bottom: 0.25rem;
        }

        .order-total button {
            background: none;
            border: none;
            color: #8b6f47;
            cursor: pointer;
            font-size: 0.875rem;
        }

        .order-total button:hover {
            background-color: rgba(235, 209, 182, 0.1);
        }

        .order-items {
            display: flex;
            gap: 1rem;
            overflow-x: auto;
        }

        .order-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            flex-shrink: 0;
        }

        .item-image {
            width: 4rem;
            height: 4rem;
            border-radius: 0.5rem;
            background-color: #e5e7eb;
            border: 1px solid rgba(235, 209, 182, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #9ca3af;
        }

        .item-details h4 {
            font-weight: 500;
            color: #111827;
            font-size: 0.875rem;
            margin-bottom: 0.25rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 100%;
        }

        .item-details p {
            font-size: 0.75rem;
            color: #6b7280;
            margin-bottom: 0.25rem;
        }

        .item-price {
            font-size: 0.75rem;
            font-weight: 500;
            color: #8b6f47;
        }

        .wishlist-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
        }

        .wishlist-card {
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .wishlist-card:hover {
            transform: scale(1.02);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        }

        .wishlist-image {
            position: relative;
            width: 100%;
            height: 12rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
        }

        .wishlist-heart {
            position: absolute;
            top: 0.75rem;
            right: 0.75rem;
            width: 2rem;
            height: 2rem;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(4px);
            border: none;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: #ef4444;
        }

        .wishlist-heart:hover {
            background-color: #fff;
        }

        .wishlist-content {
            padding: 1rem;
        }

        .wishlist-title {
            font-weight: 600;
            color: #111827;
            margin-bottom: 0.5rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 100%;
        }

        .wishlist-rating {
            display: flex;
            align-items: center;
            gap: 0.25rem;
            margin-bottom: 0.75rem;
        }

        .wishlist-rating i {
            color: #fbbf24;
        }

        .wishlist-rating span {
            font-size: 0.875rem;
            color: #6b7280;
        }

        .wishlist-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .wishlist-prices {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            flex: 1;
        }

        .current-price {
            font-weight: 600;
            color: #111827;
        }

        .original-price {
            font-size: 0.875rem;
            color: #6b7280;
            text-decoration: line-through;
        }

        .add-to-cart {
            background-color: #ebd1b6;
            color: #8b6f47;
            border: none;
            padding: 0.25rem 0.75rem;
            border-radius: 0.375rem;
            font-size: 0.875rem;
            cursor: pointer;
        }

        .add-to-cart:hover {
            background-color: #d4c0a1;
        }

        .addresses-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
        }

        .address-card {
            border-radius: 0.5rem;
        }

        .address-card.default {
            border: 2px solid #ebd1b6;
        }

        .address-card:not(.default) {
            border: 1px solid #d1d5db;
        }

        .address-header {
            padding: 1rem 1rem 0.75rem;
            border-bottom: 1px solid rgba(235, 209, 182, 0.1);
        }

        .address-header-content {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .address-title {
            font-size: 1.125rem;
            font-weight: 600;
        }

        .address-body {
            padding: 1rem;
        }

        .address-details {
            margin-bottom: 1rem;
        }

        .address-details p {
            margin-bottom: 0.5rem;
            color: #6b7280;
        }

        .address-details p:first-child {
            font-weight: 500;
            color: #111827;
        }

        .address-actions {
            display: flex;
            gap: 0.5rem;
        }

        .btn-sm {
            padding: 0.25rem 0.75rem;
            font-size: 0.875rem;
        }

        .btn-ghost {
            background: none;
            border: none;
            color: #6b7280;
            cursor: pointer;
        }

        .btn-ghost:hover {
            color: #374151;
        }

        .payment-list {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .payment-card {
            padding: 1.5rem;
        }

        .payment-card.default {
            border: 2px solid #ebd1b6;
        }

        .payment-card:not(.default) {
            border: 1px solid #d1d5db;
        }

        .payment-content {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .payment-info {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .card-brand {
            width: 3rem;
            height: 2rem;
            border-radius: 0.25rem;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 0.75rem;
            font-weight: bold;
        }

        .card-brand.visa {
            background: linear-gradient(135deg, #1e3a8a, #1e40af);
        }

        .card-brand.mastercard {
            background: linear-gradient(135deg, #dc2626, #b91c1c);
        }

        .card-details h4 {
            font-weight: 500;
            color: #111827;
            margin-bottom: 0.25rem;
        }

        .card-details p {
            font-size: 0.875rem;
            color: #6b7280;
        }

        .payment-actions {
            display: flex;
            gap: 0.5rem;
        }

        .divider {
            border: none;
            border-top: 1px solid #d1d5db;
            margin: 1.5rem 0;
        }

        .notifications-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(4px);
            border-radius: 0.5rem;
        }

        .notifications-header {
            padding: 1rem;
            border-bottom: 1px solid #e5e7eb;
        }

        .notifications-title {
            font-size: 1.125rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .notifications-title i {
            color: #8b6f47;
        }

        .notifications-subtitle {
            font-size: 0.875rem;
            color: #6b7280;
            margin-top: 0.25rem;
        }

        .notifications-body {
            padding: 1rem;
        }

        .notification-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1rem;
        }

        .notification-item:last-child {
            margin-bottom: 0;
        }

        .notification-details h4 {
            font-weight: 500;
            margin-bottom: 0.25rem;
        }

        .notification-details p {
            font-size: 0.875rem;
            color: #6b7280;
        }

        @media (min-width: 768px) {
            .profile-info {
                flex-direction: row;
                align-items: center;
            }

            .user-header {
                flex-direction: row;
                align-items: center;
                justify-content: space-between;
            }

            .section-header {
                flex-direction: row;
                align-items: center;
            }

            .order-header {
                flex-direction: row;
                align-items: center;
            }

            .payment-content {
                flex-direction: row;
                align-items: center;
            }

            .notification-item {
                flex-direction: row;
                align-items: center;
            }

            .wishlist-footer {
                flex-direction: row;
                align-items: center;
            }

            .address-header-content {
                flex-direction: row;
                align-items: center;
            }
        }

        .hidden {
            display: none;
        }

        .flex {
            display: flex;
        }

        .items-center {
            align-items: center;
        }

        .justify-between {
            justify-content: space-between;
        }

        .gap-1 { gap: 0.25rem; }
        .gap-2 { gap: 0.5rem; }
        .gap-3 { gap: 0.75rem; }
        .gap-4 { gap: 1rem; }
        .gap-6 { gap: 1.5rem; }

        .text-sm { font-size: 0.875rem; }
        .text-base { font-size: 1rem; }
        .text-lg { font-size: 1.125rem; }
        .text-xl { font-size: 1.25rem; }
        .text-2xl { font-size: 1.5rem; }

        .font-medium { font-weight: 500; }
        .font-semibold { font-weight: 600; }
        .font-bold { font-weight: bold; }

        .text-gray-500 { color: #6b7280; }
        .text-gray-600 { color: #4b5563; }
        .text-gray-900 { color: #111827; }

        .mb-2 { margin-bottom: 0.5rem; }
        .mb-3 { margin-bottom: 0.75rem; }
        .mb-4 { margin-bottom: 1rem; }
        .mb-6 { margin-bottom: 1.5rem; }

        .mt-1 { margin-top: 0.25rem; }
        .mt-4 { margin-top: 1rem; }
    </style>
</head>
<body class="<%= typeof hasSubheader !== 'undefined' ? (hasSubheader ? 'has-subheader' : '') : '' %>">
    <%- include('partials/header') %>
    <% if (typeof hasSubheader !== 'undefined' && hasSubheader) { %>
        <%- include('partials/sub-header') %>
    <% } %>

    <div class="profile-container">
        <div class="glass-card profile-header">
            <div class="profile-header-content">
                <div class="profile-info">
                    <div class="avatar-section">
                        <div class="avatar">
                            <% if (user) { %>
                                <%= user.firstName.charAt(0) + user.lastName.charAt(0) %>
                            <% } else { %>
                                SJ
                            <% } %>
                        </div>
                    </div>

                    <div class="user-details">
                        <div class="user-header">
                            <div>
                                <h1 class="user-name">
                                    <% if (user) { %>
                                        <%= user.firstName %> <%= user.lastName %>
                                    <% } else { %>
                                        Guest User
                                    <% } %>
                                </h1>
                                <p class="user-email">
                                    <% if (user) { %>
                                        <%= user.email %>
                                    <% } else { %>
                                        guest@email.com
                                    <% } %>
                                </p>
                                <div class="user-stats">
                                    <span class="stat-item">
                                        <i class="fas fa-box"></i>
                                        12 Orders
                                    </span>
                                    <span class="stat-item">
                                        <i class="fas fa-heart"></i>
                                        8 Favorites
                                    </span>
                                    <span class="badge">
                                        VIP Member
                                    </span>
                                </div>
                            </div>

                            <div class="profile-actions">
                                <button class="btn btn-outline">
                                    <i class="fas fa-cog"></i>
                                    Settings
                                </button>
                                <button class="btn btn-primary">Edit Profile</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div>
            <div class="tabs-container">
                <div class="tabs">
                    <button onclick="showTab('orders')" class="tab-btn active" data-tab="orders">
                        <i class="fas fa-box"></i>
                        Orders
                    </button>
                    <button onclick="showTab('wishlist')" class="tab-btn" data-tab="wishlist">
                        <i class="fas fa-heart"></i>
                        Wishlist
                    </button>
                    <button onclick="showTab('addresses')" class="tab-btn" data-tab="addresses">
                        <i class="fas fa-map-marker-alt"></i>
                        Addresses
                    </button>
                    <button onclick="showTab('payment')" class="tab-btn" data-tab="payment">
                        <i class="fas fa-credit-card"></i>
                        Payment
                    </button>
                </div>
            </div>

            <div id="orders-tab" class="tab-content">
                <div class="section-header">
                    <h2 class="section-title">Order History</h2>
                    <button class="btn btn-outline">
                        View All Orders
                    </button>
                </div>

                <div class="orders-list">
                    <div class="glass-card order-card">
                        <div class="order-header">
                            <div class="order-info">
                                <div class="order-details">
                                    <h3>ORD-001</h3>
                                    <p>Dec 15, 2024</p>
                                </div>
                                <span class="order-status status-delivered">
                                    Delivered
                                </span>
                            </div>
                            <div class="order-total">
                                <p>$129.99</p>
                                <button>View Details</button>
                            </div>
                        </div>

                        <div class="order-items">
                            <div class="order-item">
                                <div class="item-image">
                                    <i class="fas fa-tshirt"></i>
                                </div>
                                <div class="item-details">
                                    <h4>Organic Cotton T-Shirt</h4>
                                    <p>M • White</p>
                                    <p class="item-price">$29.99</p>
                                </div>
                            </div>
                            <div class="order-item">
                                <div class="item-image">
                                    <i class="fas fa-vest"></i>
                                </div>
                                <div class="item-details">
                                    <h4>Denim Jacket</h4>
                                    <p>L • Blue</p>
                                    <p class="item-price">$99.99</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="glass-card order-card">
                        <div class="order-header">
                            <div class="order-info">
                                <div class="order-details">
                                    <h3>ORD-002</h3>
                                    <p>Dec 8, 2024</p>
                                </div>
                                <span class="order-status status-processing">
                                    Processing
                                </span>
                            </div>
                            <div class="order-total">
                                <p>$89.99</p>
                                <button>View Details</button>
                            </div>
                        </div>

                        <div class="order-items">
                            <div class="order-item">
                                <div class="item-image">
                                    <i class="fas fa-sweater"></i>
                                </div>
                                <div class="item-details">
                                    <h4>Wool Sweater</h4>
                                    <p>M • Beige</p>
                                    <p class="item-price">$89.99</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="wishlist-tab" class="tab-content hidden">
                <div class="section-header">
                    <h2 class="section-title">My Wishlist</h2>
                    <button class="btn btn-outline">
                        Share Wishlist
                    </button>
                </div>

                <div class="wishlist-grid">
                    <div class="glass-card wishlist-card">
                        <div class="wishlist-image" style="background: linear-gradient(135deg, #fce7f3, #fbcfe8);">
                            <i class="fas fa-tshirt" style="color: #ec4899;"></i>
                            <button class="wishlist-heart">
                                <i class="fas fa-heart"></i>
                            </button>
                        </div>
                        <div class="wishlist-content">
                            <h3 class="wishlist-title">Silk Blouse</h3>
                            <div class="wishlist-rating">
                                <i class="fas fa-star"></i>
                                <span>4.8</span>
                            </div>
                            <div class="wishlist-footer">
                                <div class="wishlist-prices">
                                    <span class="current-price">$79.99</span>
                                    <span class="original-price">$99.99</span>
                                </div>
                                <button class="add-to-cart">Add to Cart</button>
                            </div>
                        </div>
                    </div>

                    <div class="glass-card wishlist-card">
                        <div class="wishlist-image" style="background: linear-gradient(135deg, #f3e8ff, #e9d5ff);">
