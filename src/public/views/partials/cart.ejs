<style>
/* =============================================================================
   CART PARTIAL STYLES
============================================================================= */

/* -----------------------------------------------------------------------------
   1. FLOATING CART TAB (right-side trigger)
----------------------------------------------------------------------------- */
.cart-tab {
    position: fixed;
    right: 0;
    top: 30%;
    transform: translateY(-50%);
    z-index: 50;
    display: flex;
    flex-direction: column;
    align-items: center;
    background-color: var(--card);
    border: 1px solid var(--border);
    border-right: none;
    border-radius: 0.5rem 0 0 0.5rem;
    padding: 0.75rem 0.6rem;
    gap: 0.4rem;
    cursor: pointer;
    box-shadow: -2px 0 12px rgba(0, 0, 0, 0.08);
    transition: background-color 0.2s, box-shadow 0.2s, transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    user-select: none;
}

.cart-tab.hidden {
    transform: translateY(-50%) translateX(100%);
}

.cart-tab:hover {
    background-color: var(--muted);
    box-shadow: -3px 0 16px rgba(0, 0, 0, 0.12);
}

.cart-tab svg {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--foreground);
}

.cart-tab-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--foreground);
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
}

.cart-tab-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 9999px;
    background-color: var(--primary);
    color: var(--primary-foreground);
    font-size: 0.6rem;
    font-weight: 700;
    line-height: 1;
}

/* -----------------------------------------------------------------------------
   2. CART OVERLAY (backdrop)
----------------------------------------------------------------------------- */
.cart-overlay {
    position: fixed;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 6;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
}

.cart-overlay.active {
    opacity: 1;
    visibility: visible;
}

/* -----------------------------------------------------------------------------
   3. CART DRAWER
----------------------------------------------------------------------------- */
.cart-drawer {
    position: fixed;
    top: 0;
    right: 0;
    height: 100dvh;
    width: 100%;
    max-width: 20rem;
    z-index: 6;
    display: flex;
    flex-direction: column;
    background-color: var(--background);
    color: var(--secondary);
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: -4px 0 24px rgba(0, 0, 0, 0.25);
}

.cart-drawer.active {
    transform: translateX(0);
}

/* -----------------------------------------------------------------------------
   4. CART HEADER
----------------------------------------------------------------------------- */
.cart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 1.5rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    flex-shrink: 0;
    background-color: var(--foreground);
}

.cart-header-left h2 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--background);
    margin: 0 0 0.15rem 0;
}

.cart-item-count {
    font-size: 0.8rem;
    color: var(--accent);
    letter-spacing: 0.04em;
}

.cart-close-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: rgba(255, 255, 255, 0.5);
    padding: 0.4rem;
    border-radius: 0.375rem;
    transition: color 0.2s, background-color 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
}

.cart-close-btn:hover {
    color: var(--accent);
    background-color: rgba(255, 255, 255, 0.08);
}

.cart-close-btn svg {
    width: 1.25rem;
    height: 1.25rem;
}

/* -----------------------------------------------------------------------------
   5. FREE SHIPPING PROGRESS BAR
----------------------------------------------------------------------------- */
.cart-shipping-bar {
    padding: 0.75rem 1.5rem;
    border-bottom: 1px solid var(--foreground);
    flex-shrink: 0;
}

.cart-shipping-bar-text {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
    font-size: 0.78rem;
    color: #111111;
}

.cart-shipping-bar-text .unlocked {
    color: #4ade80;
    font-weight: 500;
}

.cart-shipping-bar-text .threshold {
    color: var(--muted-foreground);
}

.progress-track {
    width: 100%;
    height: 3px;
    background-color: var(--muted);
    border-radius: 9999px;
    overflow: hidden;
}

.progress-fill {
    height: 100%;
    background-color: var(--accent);
    color: var(--accent);
    border-radius: 9999px;
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

/* -----------------------------------------------------------------------------
   6. CART ITEMS LIST
----------------------------------------------------------------------------- */
.cart-items {
    flex: 1;
    overflow-y: auto;
    padding: 0.5rem 0;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
}

.cart-items::-webkit-scrollbar { width: 4px; }
.cart-items::-webkit-scrollbar-track { background: transparent; }
.cart-items::-webkit-scrollbar-thumb {
    background-color: var(--border);
    border-radius: 9999px;
}

.cart-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 1rem;
    padding: 2rem;
    text-align: center;
    color: var(--foreground);
}

.cart-empty svg { width: 3rem; height: 3rem; color: var(--foreground); }
.cart-empty p { font-size: 0.9rem; margin: 0; }

.cart-item {
    display: flex;
    gap: 1rem;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--border);
    position: relative;
    transition: background-color 0.2s;
}

.cart-item:last-child { border-bottom: none; }
.cart-item:hover { background-color: var(--muted); }

.cart-item-image {
    width: 5rem;
    height: 5rem;
    border-radius: 0.5rem;
    object-fit: cover;
    flex-shrink: 0;
    background-color: var(--muted);
}

.cart-item-details {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
}

.cart-item-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--foreground);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.cart-item-variant { font-size: 0.75rem; color: var(--muted-foreground); }

.cart-item-price-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 0.4rem;
}

.cart-item-original-price {
    font-size: 0.75rem;
    color: var(--muted-foreground);
    text-decoration: line-through;
}

.cart-item-price { font-size: 0.9rem; font-weight: 600; color: var(--primary); }

.cart-item-controls {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: space-between;
    flex-shrink: 0;
}

.cart-item-delete {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--muted-foreground);
    padding: 0.25rem;
    border-radius: 0.25rem;
    transition: color 0.2s;
    display: flex;
}

.cart-item-delete:hover { color: #f87171; }
.cart-item-delete svg { width: 1rem; height: 1rem; }

.cart-qty {
    display: flex;
    align-items: center;
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    overflow: hidden;
}

.cart-qty-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--muted-foreground);
    width: 1.75rem;
    height: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.15s, color 0.15s;
    font-size: 1rem;
    line-height: 1;
}

.cart-qty-btn:hover { background-color: var(--muted); color: var(--foreground); }
.cart-qty-btn:disabled { opacity: 0.3; cursor: not-allowed; }

.cart-qty-value {
    min-width: 1.75rem;
    text-align: center;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--foreground);
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
    padding: 0 0.25rem;
    line-height: 1.75rem;
}

/* -----------------------------------------------------------------------------
   7. CART FOOTER
----------------------------------------------------------------------------- */
.cart-footer {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 1.25rem 1.5rem 1.5rem;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.cart-totals { display: flex; flex-direction: column; gap: 0.5rem; }

.cart-total-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.55);
}

.cart-total-row.grand-total {
    color: #f0f0f0;
    font-size: 1.05rem;
    font-weight: 700;
    margin-top: 0.25rem;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
}

.cart-total-row .free-shipping-label { color: #4ade80; font-weight: 500; }

.cart-checkout-btn {
    margin-top: 0.75rem;
    width: 100%;
    padding: 0.9rem 1rem;
    background-color: #f0f0f0;
    color: #111111;
    border: none;
    border-radius: 0.5rem;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    transition: background-color 0.2s, transform 0.1s;
}

.cart-checkout-btn:hover { background-color: #ffffff; }
.cart-checkout-btn:active { transform: scale(0.99); }
.cart-checkout-btn svg { width: 1rem; height: 1rem; }

.cart-secure-note {
    text-align: center;
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.25);
    margin-top: 0.25rem;
    letter-spacing: 0.03em;
}
</style>

<!-- ─── Floating Cart Tab ──────────────────────────────────────────────────── -->
<button class="cart-tab" id="cart-tab-btn" aria-label="Open cart">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
        <path d="M3 6h18"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
    </svg>
    <span class="cart-tab-label">Cart</span>
    <span class="cart-tab-badge" id="cart-tab-badge">0</span>
</button>

<!-- ─── Cart Backdrop ─────────────────────────────────────────────────────── -->
<div class="cart-overlay" id="cart-overlay"></div>

<!-- ─── Cart Drawer ───────────────────────────────────────────────────────── -->
<aside class="cart-drawer" id="cart-drawer" aria-label="Shopping cart">

    <!-- Header -->
    <div class="cart-header">
        <div class="cart-header-left">
            <h2>Your Cart</h2>
            <span class="cart-item-count" id="cart-item-count">0 items</span>
        </div>
        <button class="cart-close-btn" id="cart-close-btn" aria-label="Close cart">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
            </svg>
        </button>
    </div>

    <!-- Free Shipping Bar -->
    <div class="cart-shipping-bar" id="cart-shipping-bar">
        <div class="cart-shipping-bar-text">
            <span id="shipping-bar-msg">
                Add <strong id="shipping-remaining">$<%= freeShippingThreshold %></strong> more for free shipping
            </span>
            <span class="threshold">$<%= freeShippingThreshold %></span>
        </div>
        <div class="progress-track">
            <div class="progress-fill" id="shipping-progress" style="width: 0%"></div>
        </div>
    </div>

    <!-- Items -->
    <div class="cart-items" id="cart-items-list">
        <% if (!cart || cart.items.length === 0) { %>
            <div class="cart-empty" id="cart-empty-state">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
                    <path d="M3 6h18"/>
                    <path d="M16 10a4 4 0 0 1-8 0"/>
                </svg>
                <p>Your cart is empty</p>
            </div>
        <% } else { %>
            <% cart.items.forEach(function(item) { %>
                <div class="cart-item" data-id="<%= item.id %>">
                    <img
                        class="cart-item-image"
                        src="<%= item.image %>"
                        alt="<%= item.name %>"
                    />
                    <div class="cart-item-details">
                        <span class="cart-item-name"><%= item.name %></span>
                        <% if (item.variant) { %>
                            <span class="cart-item-variant"><%= item.variant %></span>
                        <% } %>
                        <div class="cart-item-price-row">
                            <% if (item.originalPrice) { %>
                                <span class="cart-item-original-price">$<%= item.originalPrice.toFixed(2) %></span>
                            <% } %>
                            <span class="cart-item-price">$<%= item.price.toFixed(2) %></span>
                        </div>
                    </div>
                    <div class="cart-item-controls">
                        <button class="cart-item-delete" data-id="<%= item.id %>" aria-label="Remove item">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M3 6h18"/><path d="M19 6l-1 14H6L5 6"/>
                                <path d="M10 11v6"/><path d="M14 11v6"/>
                                <path d="M9 6V4h6v2"/>
                            </svg>
                        </button>
                        <div class="cart-qty">
                            <button class="cart-qty-btn" data-action="decrease" data-id="<%= item.id %>"
                                    <%= item.quantity <= 1 ? 'disabled' : '' %>>−</button>
                            <span class="cart-qty-value"><%= item.quantity %></span>
                            <button class="cart-qty-btn" data-action="increase" data-id="<%= item.id %>">+</button>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>

    <!-- Footer Totals -->
    <% if (cart && cart.items.length > 0) { %>
        <div class="cart-footer" id="cart-footer">
            <div class="cart-totals">
                <div class="cart-total-row">
                    <span>Subtotal</span>
                    <span id="cart-subtotal">$<%= cart.subtotal.toFixed(2) %></span>
                </div>
                <div class="cart-total-row">
                    <span>Shipping</span>
                    <% if (cart.subtotal >= freeShippingThreshold) { %>
                        <span class="free-shipping-label">Free</span>
                    <% } else { %>
                        <span id="cart-shipping-cost">Calculated at checkout</span>
                    <% } %>
                </div>
                <div class="cart-total-row grand-total">
                    <span>Total</span>
                    <span id="cart-total">$<%= cart.subtotal.toFixed(2) %></span>
                </div>
            </div>
            <button class="cart-checkout-btn" id="cart-checkout-btn">
                Checkout
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
            </button>
            <p class="cart-secure-note">Secure checkout powered by Stripe</p>
        </div>
    <% } %>

</aside>

<script src="../../js/cart.js"></script>
