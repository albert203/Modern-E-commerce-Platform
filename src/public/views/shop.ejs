    <script>
      // Toggle filters sidebar
      function toggleFilters() {
        const filters = document.getElementById('filters');
        filters.classList.toggle('show');
      }

      // Price range sliders (Exact Match to Claude's)
      const minPrice = document.getElementById('minPrice');
      const maxPrice = document.getElementById('maxPrice');
      const minPriceValue = document.getElementById('minPriceValue');
      const maxPriceValue = document.getElementById('maxPriceValue');

      function updatePriceValues() {
        const min = parseInt(minPrice.value);
        const max = parseInt(maxPrice.value);
        if (min >= max) {
          minPrice.value = max - 10;
        }
        minPriceValue.textContent = minPrice.value;
        maxPriceValue.textContent = maxPrice.value;
      }

      minPrice.addEventListener('input', updatePriceValues);
      maxPrice.addEventListener('input', updatePriceValues);

      // Handle mobile filter close on outside click
      document.addEventListener('click', function(e) {
        const filters = document.getElementById('filters');
        const toggleBtn = document.querySelector('.filter-toggle');
        if (window.innerWidth <= 768 && filters.classList.contains('show') && !filters.contains(e.target) && !toggleBtn.contains(e.target)) {
          filters.classList.remove('show');
        }
      });
    </script>
