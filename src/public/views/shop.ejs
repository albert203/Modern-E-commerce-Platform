<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <link rel="stylesheet" href="https://unicons.iconscout.com/release/v4.0.0/css/line.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="../css/global.css">
    <title>Shop</title>
    
    <link rel="preconnect" href="https://unicons.iconscout.com">
    <link rel="preconnect" href="https://cdnjs.cloudflare.com">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Cardo:ital,wght@0,400;0,700;1,400&display=swap');
      @import url('https://fonts.googleapis.com/css2?family=Source+Sans+Pro&display=swap');

      :root {
        --eerie-black: #1b1b1b;
        --primary-purple: #7d2ae8;
        --primary-purple-hover: #5a1bbd;
        --accent-cyan: #37c5f0;
        --white: #ffffff;
        --black: #000000;
        --gray-light: #aaaaaa;
        --red: #fa0000;
        --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        --shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        --radius: 8px;
        --radius-sm: 6px;
        --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: 'Source Sans Pro', sans-serif;
        background: var(--white);
        color: var(--black);
        line-height: 1.6;
      }

      /* Modal screen */
      .home-section {
        position: fixed;
        height: 100vh;
        width: 100%;
        background-size: cover;
        background-position: center;
      }

      .home-section::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        height: 100%;
        width: 100%;
        background-color: rgba(0, 0, 0, 0.6);
        z-index: 100;
        opacity: 0;
        pointer-events: none;
        transition: var(--transition);
      }

      .home-section.show::before {
        opacity: 1;
        pointer-events: auto;
      }

      /* Modal form */
      .modal {
        position: fixed;
        max-width: 450px;
        min-width: 320px;
        width: 100%;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%) scale(1.2);
        z-index: 101;
        background: var(--white);
        padding: 25px;
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        opacity: 0;
        pointer-events: none;
        transition: var(--transition);
      }

      .home-section.show .modal {
        opacity: 1;
        pointer-events: auto;
        transform: translate(-50%, -50%) scale(1);
      }

      #signup_form {
        display: none;
      }

      .modal.active #signup_form {
        display: block;
      }

      .modal.active .login_form {
        display: none;
      }

      .form_close {
        position: absolute;
        top: 10px;
        right: 20px;
        color: var(--black);
        font-size: 22px;
        opacity: 0.7;
        cursor: pointer;
      }

      .modal h2 {
        font-family: 'Cardo', serif;
        font-size: 22px;
        color: var(--black);
        text-align: center;
      }

      .input-group {
        position: relative;
        margin-top: 30px;
        width: 100%;
        height: 40px;
      }

      .input-group input {
        height: 100%;
        width: 100%;
        border: none;
        outline: none;
        padding: 0 30px;
        color: var(--black);
        transition: var(--transition);
        border-bottom: 1.5px solid var(--gray-light);
      }

      .input-group input:focus {
        border-color: var(--primary-purple);
      }

      .input-group i {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        font-size: 20px;
        color: var(--gray-light);
      }

      .input-group i.email,
      .input-group i.profileIcon {
        left: 0;
      }

      .input-group i.password {
        left: 0;
      }

      .input-group input:focus ~ i.email,
      .input-group input:focus ~ i.password {
        color: var(--primary-purple);
      }

      .input-group i.pw_hide {
        right: 0;
        font-size: 18px;
        cursor: pointer;
      }

      .checkbox-group {
        margin-top: 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .modal a {
        color: var(--primary-purple);
        font-size: 12px;
      }

      .modal a:hover {
        text-decoration: underline;
      }

      .checkbox {
        display: flex;
        column-gap: 8px;
        white-space: nowrap;
      }

      .checkbox input {
        accent-color: var(--primary-purple);
      }

      .form-button .checkbox label {
        font-size: 12px;
        cursor: pointer;
        user-select: none;
        color: var(--black);
      }

      .modal .form-button {
        background: var(--primary-purple);
        margin-top: 30px;
        width: 100%;
        padding: 10px 0;
        border-radius: var(--radius);
        font-family: 'Cardo', serif;
        color: var(--white);
        border: none;
        cursor: pointer;
        transition: var(--transition);
      }

      .modal .form-button:hover {
        background: var(--primary-purple-hover);
        transform: translateY(-2px);
      }

      .login_signup {
        font-size: 12px;
        text-align: center;
        margin-top: 15px;
      }

      .form-button:active {
        transform: scale(0.98);
      }

      .validation-message {
        color: var(--red);
        font-size: 12px;
      }

      #loginError {
        color: var(--red);
      }

      /* Main Container */
      .main-container {
        max-width: 1400px;
        margin: 80px auto;
        padding: 2rem;
        display: flex;
        gap: 2rem;
        position: relative;
        z-index: 1;
      }

      /* Filters Container */
      .filters-container {
        background-color: var(--white);
        padding: 1.5rem;
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        position: fixed;
        top: 0;
        left: 0;
        margin-top: calc(var(--nav-height) + var(--sub-header-height));
        height: calc(100vh - var(--nav-height) - var(--sub-header-height));
        overflow-y: auto;
        transform: translateX(-100%);
        opacity: 0;
        transition: var(--transition);
        z-index: 200;
      }

      .filters-container.show {
        transform: translateX(0);
        opacity: 1;
      }

      .filter-title {
        font-family: 'Cardo', serif;
        font-size: 1.25rem;
        margin-bottom: 1.5rem;
        color: var(--black);
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .filter-group {
        margin-bottom: 1.5rem;
      }

      .filter-group label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 500;
        color: var(--black);
        font-size: 0.875rem;
      }

      .filter-group select {
        width: 100%;
        padding: 0.75rem;
        border: 1px solid var(--gray-light);
        border-radius: var(--radius-sm);
        font-size: 0.875rem;
        transition: var(--transition);
        background: var(--white);
        color: var(--black);
      }

      .filter-group select:focus {
        outline: none;
        border-color: var(--primary-purple);
        box-shadow: 0 0 0 3px rgba(125, 42, 232, 0.1);
      }

      /* Price Range Filter (Exact Match to Claude's) */
      .price-range {
        display: flex;
        gap: 0.75rem;
        align-items: center;
      }

      .price-range input[type="range"] {
        flex: 1;
        height: 6px;
        background: var(--gray-light);
        border-radius: 3px;
        outline: none;
        -webkit-appearance: none;
      }

      .price-range input[type="range"]::-webkit-slider-thumb {
        -webkit-appearance: none;
        width: 20px;
        height: 20px;
        background: var(--primary-purple);
        border-radius: 50%;
        cursor: pointer;
      }

      .price-values {
        display: flex;
        justify-content: space-between;
        margin-top: 0.5rem;
        font-size: 0.875rem;
        color: var(--black);
      }

      .apply-filters-btn {
        width: 100%;
        padding: 0.75rem;
        background: var(--primary-purple);
        color: var(--white);
        border: none;
        border-radius: var(--radius);
        font-family: 'Cardo', serif;
        font-weight: 500;
        cursor: pointer;
        transition: var(--transition);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
      }

      .apply-filters-btn:hover {
        background: var(--primary-purple-hover);
        transform: translateY(-2px);
        box-shadow: var(--shadow);
      }

      /* Filter Toggle Button */
      .filter-toggle {
        position: fixed;
        left: 20px;
        top: 50%;
        transform: translateY(-50%);
        width: 48px;
        height: 48px;
        background: var(--white);
        border: 1px solid var(--gray-light);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        box-shadow: var(--shadow);
        z-index: 50;
        transition: var(--transition);
      }

      .filter-toggle:hover {
        background: var(--accent-cyan);
        color: var(--black);
        transform: translateY(-50%) scale(1.05);
      }

      .filter-toggle .icon {
        font-size: 1rem;
        transition: var(--transition);
      }

      .filters-container.show + .filter-toggle .icon {
        transform: rotate(180deg);
      }

      /* Shop Container */
      .shop-container {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        max-width: 1400px;
        margin: 0 auto;
        transition: var(--transition);
      }

      .filters-container.show ~ .shop-container {
        transform: translateX(150px);
      }

      /* Shop Grid */
      .shop-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 25px;
        width: 100%;
      }

      .shop-item {
        background-color: var(--white);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
        transition: var(--transition);
        position: relative;
      }

      .shop-item:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
      }

      .shop-item img {
        width: 100%;
        height: 400px;
        object-fit: cover;
        transition: var(--transition);
      }

      .shop-item:hover img {
        transform: scale(1.05);
      }

      .shop-item .item-details {
        padding: 15px;
      }

      .shop-item .item-caption {
        font-family: 'Cardo', serif;
        font-size: 16px;
        color: var(--black);
        font-weight: 600;
        margin-bottom: 8px;
      }

      .shop-item .item-price {
        font-size: 16px;
        color: var(--black);
        font-weight: 500;
      }

      .shop-item a {
        text-decoration: none;
        color: var(--black);
      }

      /* Sizing and Stock Options */
      .sizes-inner-container {
        position: absolute;
        bottom: 80px;
        left: 0;
        width: 100%;
        background: rgba(255, 255, 255, 0.95);
        height: 0;
        overflow: hidden;
        display: flex;
        justify-content: center;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        opacity: 0;
        transition: height var(--transition), opacity var(--transition), padding var(--transition);
        padding: 0 15px;
      }

      .shop-item:hover .sizes-inner-container {
        opacity: 1;
        height: 60px;
        padding: 10px 15px;
      }

      .size-item {
        color: var(--black);
        background-color: var(--white);
        border: 1px solid var(--black);
        width: 40px;
        height: 40px;
        display: flex;
        justify-content: center;
        align-items: center;
        border-radius: 50%;
        cursor: pointer;
        position: relative;
        transition: var(--transition);
        font-size: 14px;
        font-weight: 500;
      }

      .size-item:hover {
        background-color: var(--primary-purple);
        color: var(--white);
        border-color: var(--primary-purple);
      }

      .size-item.out-of-stock {
        background-color: rgba(211, 100, 100, 0.44);
        cursor: not-allowed;
      }

      .size-item.out-of-stock::after {
        content: '';
        position: absolute;
        width: 2px;
        height: 40px;
        background-color: var(--red);
        transform: translateX(-50%) rotate(45deg);
        top: 0;
        left: 50%;
      }

      .size-item.out-of-stock:hover {
        background-color: rgba(211, 100, 100, 0.44);
        color: var(--black);
        border-color: var(--black);
      }

      /* Mailing Banner */
      .mail-container {
        display: flex;
        justify-content: space-evenly;
        align-items: stretch;
        width: 100%;
        max-width: 1400px;
        margin: 4rem auto;
        height: 500px;
        box-sizing: border-box;
      }

      .mail-container .mail-text-wrapper,
      .mail-container .img-wrapper {
        width: 47.5%;
        display: flex;
        justify-content: center;
        align-items: center;
      }

      .mail-container .mail-text {
        width: 100%;
        height: 100%;
        background: var(--eerie-black);
        color: var(--white);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        border-radius: var(--radius);
        padding: 20px;
        box-sizing: border-box;
      }

      .mail-text h2 {
        font-family: 'Cardo', serif;
        font-size: 2rem;
        font-weight: 600;
        margin-bottom: 20px;
        text-transform: uppercase;
      }

      .mail-text .mailing-form {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        width: 100%;
      }

      .mailing-form input {
        width: 55%;
        padding: 10px;
        margin: 20px 0 15px 0;
        border: none;
        border-radius: 3px;
        font-size: 16px;
      }

      .mailing-form button {
        width: 65%;
        padding: 10px;
        margin: 10px 0;
        border: none;
        background: var(--accent-cyan);
        color: var(--black);
        font-family: 'Cardo', serif;
        font-weight: bold;
        cursor: pointer;
        border-radius: 15px;
        transition: var(--transition);
      }

      .mailing-form button:hover {
        background: var(--primary-purple);
        color: var(--white);
        transform: translateY(-2px);
      }

      .img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: var(--radius);
        object-position: 50% 24%;
      }

      /* Responsive Design */
      @media (max-width: 768px) {
        .main-container {
          padding: 1rem;
          flex-direction: column;
        }

        .filters-container {
          width: 100vw;
          height: 100vh;
          z-index: 200;
        }

        .filters-container.show ~ .shop-container {
          transform: translateX(0);
        }

        .shop-grid {
          grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
          gap: 15px;
        }

        .mail-container {
          flex-direction: column;
          height: auto;
        }

        .mail-container .mail-text-wrapper,
        .mail-container .img-wrapper {
          width: 100%;
          height: 300px;
        }
      }
    </style>
  </head>
  <body class="<%= typeof hasSubheader !== 'undefined' ? (hasSubheader ? 'has-subheader' : '') : '' %>">

    <%- include('partials/header') %>
    <% if (typeof hasSubheader !== 'undefined' && hasSubheader) { %>
        <%- include('partials/sub-header') %>
    <% } %>

    <!-- Modal Login/Signup Form -->
    <section class="home-section">
      <div class="modal">
        <i class="uil uil-times form_close"></i>
        <!-- Login Form -->
        <div class="form login_form">
          <form id="loginForm" action="/api/login" method="POST">
            <h2>Login</h2>
            <div class="input-group">
              <input
                type="email"
                name="email"
                id="loginEmail"
                placeholder="Enter your email"
              />
              <i class="uil uil-envelope-alt email"></i>
            </div>
            <div class="input-group">
              <input
                type="password"
                name="password"
                id="loginPassword"
                placeholder="Enter your password"
              />
              <i class="uil uil-lock password"></i>
              <i class="uil uil-eye-slash pw_hide"></i>
            </div>
            <div class="checkbox-group">
              <span class="checkbox">
                <input type="checkbox" id="check" />
                <label for="check">Remember me</label>
              </span>
              <a class="forgot-password" href="#">Forgot password?</a>
            </div>
            <button type="submit" class="form-button">Login Now</button>
            <div class="login_error" id="loginError"></div>
            <div class="login_signup">
              Don't have an account? <a href="#" id="signup">Signup</a>
            </div>
          </form>
        </div>

        <!-- Sign-up Form -->
        <div class="form">
          <form id="signup_form">
            <h2>Signup</h2>
            <div class="input-group">
              <i class="gg--profile profileIcon"></i>
              <input
                id="first-name"
                type="text"
                autocomplete="given-name"
                placeholder="Enter first name"
              />
            </div>
            <div class="validation-message" id="firstNameError"></div>
            <div class="input-group">
              <i class="gg--profile profileIcon"></i>
              <input
                id="last-name"
                type="text"
                autocomplete="family-name"
                placeholder="Enter last name"
              />
            </div>
            <div class="validation-message" id="lastNameError"></div>
            <div class="input-group">
              <input
                id="email"
                type="email"
                autocomplete="email"
                placeholder="Email"
              />
              <i class="uil uil-envelope-alt email"></i>
            </div>
            <div class="validation-message" id="emailError"></div>
            <div class="input-group">
              <input
                id="password"
                type="password"
                placeholder="Create Password"
              />
              <i class="uil uil-lock password"></i>
              <i class="uil uil-eye-slash pw_hide"></i>
            </div>
            <div class="validation-message" id="passwordError"></div>
            <div class="input-group">
              <input
                id="confirm-password"
                type="password"
                placeholder="Confirm Password"
              />
              <i class="uil uil-lock password"></i>
              <i class="uil uil-eye-slash pw_hide"></i>
            </div>
            <div class="validation-message" id="confirmPasswordError"></div>
            <button class="form-button signup-button" type="submit">
              Signup Now
            </button>
            <div class="login_signup">
              Already have an account? <a href="#" id="login">Login</a>
            </div>
          </form>
        </div>
      </div>
    </section>

    <!-- shop and filter container -->
    <main class="main-container">
      <div class="filters-container" id="filters">
        <h3 class="filter-title"><i class="fas fa-filter"></i> Filter by</h3>
        <form id="filterForm">
          <!-- Filter by Category -->
          <div class="filter-group">
            <label for="category" class="filter-label">Category</label>
            <select id="category" name="category">
              <option value="">All</option>
              <option value="men">Men</option>
              <option value="women">Women</option>
              <option value="kids">Kids</option>
            </select>
          </div>
          <!-- Filter by Price Range (Exact Match to Claude's) -->
          <div class="filter-group">
            <label class="filter-label">Price Range</label>
            <div class="price-range">
              <input type="range" id="minPrice" name="minPrice" min="0" max="500" value="0">
              <input type="range" id="maxPrice" name="maxPrice" min="0" max="500" value="500">
            </div>
            <div class="price-values">
              <span>$<span id="minPriceValue">0</span></span>
              <span>$<span id="maxPriceValue">500</span></span>
            </div>
          </div>
          <!-- Filter by Size -->
          <div class="filter-group">
            <label for="size" class="filter-label">Size</label>
            <select id="size" name="size">
              <option value="">All Sizes</option>
              <option value="xs">XS</option>
              <option value="s">S</option>
              <option value="m">M</option>
              <option value="l">L</option>
              <option value="xl">XL</option>
            </select>
          </div>
          <!-- Filter by Color -->
          <div class="filter-group">
            <label for="color" class="filter-label">Color</label>
            <select id="color" name="color">
              <option value="">All Colors</option>
              <option value="black">Black</option>
              <option value="white">White</option>
              <option value="red">Red</option>
              <option value="blue">Blue</option>
              <option value="green">Green</option>
              <option value="yellow">Yellow</option>
            </select>
          </div>
          <!-- Filter by Brand -->
          <div class="filter-group">
            <label for="brand" class="filter-label">Brand</label>
            <select id="brand" name="brand">
              <option value="">All Brands</option>
              <option value="nike">Nike</option>
              <option value="adidas">Adidas</option>
              <option value="zara">Zara</option>
              <option value="hm">H&M</option>
              <option value="uniqlo">Uniqlo</option>
            </select>
          </div>
          <!-- Filter by Rating -->
          <div class="filter-group">
            <label for="rating" class="filter-label">Rating</label>
            <select id="rating" name="rating">
              <option value="">All Ratings</option>
              <option value="5">5 Stars</option>
              <option value="4">4 Stars & Up</option>
              <option value="3">3 Stars & Up</option>
              <option value="2">2 Stars & Up</option>
              <option value="1">1 Star & Up</option>
            </select>
          </div>
          <!-- Filter by Availability -->
          <div class="filter-group">
            <label for="availability" class="filter-label">Availability</label>
            <select id="availability" name="availability">
              <option value="">All</option>
              <option value="in-stock">In Stock</option>
              <option value="out-of-stock">Out of Stock</option>
            </select>
          </div>
          <!-- Apply Filters Button -->
          <button type="submit" class="apply-filters-btn"><i class="fas fa-check"></i> Apply Filters</button>
        </form>
      </div>
      <button class="filter-toggle" onclick="toggleFilters()">
        <i class="fas fa-chevron-right icon"></i>
      </button>
      <div class="shop-container">
        <div class="shop-grid">
          <div class="shop-item">
            <a href="#">
              <img
                src="../assets/images/don-delfin-almonte-ebTNU_YTWgc-unsplash.jpg"
                alt="Gotchii Tee"
              />
              <ul class="sizes-inner-container">
                <li class="size-item">XS</li>
                <li class="size-item">S</li>
                <li class="size-item out-of-stock">M</li>
                <li class="size-item">L</li>
                <li class="size-item out-of-stock">XL</li>
                <li class="size-item">XXL</li>
